# Environment Configuration for Agentic RAG System
# Copy this to .env and fill in your actual API keys

# ==============================================
# LLM API Keys (Required)
# ==============================================

# Groq API Key (Free tier: groq.com/colab)
# Model: llama-3.3-70b-versatile
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini API Key (Fallback model)
# Model: gemini-1.5-flash
# Get key: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================
# Optional: Web Search
# ==============================================

# Tavily Search API Key (For web research in agent)
# Get key: https://tavily.com/
# Leave blank to disable web search
TAVILY_API_KEY=your_tavily_api_key_here

# ==============================================
# Database
# ==============================================

# SQLAlchemy connection string
DATABASE_URL=sqlite:///./database.db

# ==============================================
# Server Configuration
# ==============================================

# FastAPI server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Environment: development, staging, production
ENVIRONMENT=development

# ==============================================
# Logging
# ==============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
